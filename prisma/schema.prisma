generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
}

enum PartyStatus {
  OPEN
  FULL
  PENDING_SETTLEMENT
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  VERIFIED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ---------------------------------------------------------
// Models
// ---------------------------------------------------------

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String?
  name       String
  avatarUrl  String?
  role       Role     @default(USER)
  provider   Provider @default(LOCAL)
  googleId   String?  @unique
  isVerified Boolean  @default(false)
  
  // Payment Info
  promptPayNumber String?
  promptPayName   String?

  // Relations
  reviews          Review[]
  partiesLed       Party[]                @relation("PartyLeader")
  joinedParties    PartyMember[]
  ownedRestaurants Restaurant[]           @relation("RestaurantOwner")
  savedRestaurants SavedRestaurant[]
  addedOrderItems  PartyOrderItem[]       @relation("AddedBy")
  sharedOrderItems PartyOrderItemSharer[]
  chatMessages     ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  lat         Float
  lng         Float
  category    String?

  // Relations
  images         RestaurantImage[]
  reviews        Review[]
  menus          Menu[]
  parties        Party[]
  operatingHours OperatingHour[]
  ownerId        String?
  owner          User?             @relation("RestaurantOwner", fields: [ownerId], references: [id])
  savedBy        SavedRestaurant[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model OperatingHour {
  id        String    @id @default(uuid())
  day       DayOfWeek
  openTime  String // Format: "HH:mm"
  closeTime String // Format: "HH:mm"
  isClosed  Boolean   @default(false)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model RestaurantImage {
  id      String  @id @default(uuid())
  url     String
  isCover Boolean @default(false)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model SavedRestaurant {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  savedAt      DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
}

model Menu {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  price       Float
  category    String  @default("others")
  imageUrl    String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  orderItems PartyOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Party {
  id              String      @id @default(uuid())
  name            String?
  details         String?     @db.Text
  meetupTime      DateTime
  maxParticipants Int
  status          PartyStatus @default(OPEN)
  contactInfo     String
  serviceCharge   Float       @default(0)
  vat             Float       @default(0)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  leaderId String
  leader   User   @relation("PartyLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members    PartyMember[]
  orderItems PartyOrderItem[]
  reviews    Review[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartyMember {
  id       String   @id @default(uuid())
  joinedAt DateTime @default(now())

  // Payment Tracking
  paymentStatus  PaymentStatus @default(PENDING)
  paymentSlipUrl String?       @db.Text
  paidAt         DateTime?

  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
}

model PartyOrderItem {
  id       String @id @default(uuid())
  
  partyId  String
  party    Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  addedById String
  addedBy   User  @relation("AddedBy", fields: [addedById], references: [id], onDelete: Cascade)

  // เมนูทางการ (อ้างอิง Menu)
  menuId   String?
  menu     Menu?   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  // เมนูพิเศษ (Custom Item)
  isCustom Boolean @default(false)
  name     String? // ชื่อเมนู (กรณี custom)
  price    Float?  // ราคาต่อหน่วย (กรณี custom)

  quantity Int     @default(1) // จำนวนที่สั่ง

  sharers  PartyOrderItemSharer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartyOrderItemSharer {
  id               String @id @default(uuid())
  
  partyOrderItemId String
  partyOrderItem   PartyOrderItem @relation(fields: [partyOrderItemId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([partyOrderItemId, userId])
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String? @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  text      String?  @db.Text
  imageUrl  String?  @db.Text
  type      String   @default("MESSAGE") // MESSAGE, SYSTEM
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}
