// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  OWENER
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
}

enum PartyStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------
// Models
// ---------------------------------------------------------

model User {
  id        String   @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  email     String   @unique
  password  String?
  name      String
  avatarUrl String?
  role      Role     @default(USER) // 🌟 ปรับให้ใช้ Enum Role
  provider  Provider @default(LOCAL) // 🌟 ปรับให้ใช้ Enum Provider
  googleId  String?  @unique

  // Relations
  reviews       Review[]
  partiesLed    Party[]       @relation("PartyLeader")
  joinedParties PartyMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id          String  @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  name        String
  description String? @db.Text
  lat         Float
  lng         Float
  category    String?

  // Relations
  images  RestaurantImage[]
  reviews Review[]
  menus   Menu[]
  parties Party[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model RestaurantImage {
  id      String  @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  url     String
  isCover Boolean @default(false)

  // Relations
  restaurantId String // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Menu {
  id          String  @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  name        String
  description String? @db.Text
  price       Float
  category    String  @default("others")
  imageUrl    String?

  // Relations
  restaurantId String // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Party {
  id              String      @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  name            String?
  details         String?     @db.Text
  meetupTime      DateTime
  maxParticipants Int
  status          PartyStatus @default(OPEN)
  contactInfo     String

  // Relations
  restaurantId String // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  leaderId String // 🌟 เปลี่ยน Foreign Key เป็น String
  leader   User   @relation("PartyLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members PartyMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartyMember {
  id       String   @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  joinedAt DateTime @default(now())

  // Relations
  partyId String // 🌟 เปลี่ยน Foreign Key เป็น String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  userId String // 🌟 เปลี่ยน Foreign Key เป็น String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraint: ป้องกัน User คนเดิมกดเข้าร่วมตี้เดิมซ้ำ
  @@unique([partyId, userId])
}

model Review {
  id      String  @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  rating  Int
  comment String? @db.Text

  // Relations
  userId String // 🌟 เปลี่ยน Foreign Key เป็น String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantId String // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum Role {
  USER
  OWENER
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
}

enum PartyStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------
// Models
// ---------------------------------------------------------

model User {
  id            String        @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  email         String        @unique
  password      String?       
  name          String
  avatarUrl     String?       
  role          Role          @default(USER)     // 🌟 ปรับให้ใช้ Enum Role
  provider      Provider      @default(LOCAL)    // 🌟 ปรับให้ใช้ Enum Provider
  googleId      String?       @unique           
  
  // Relations
  reviews       Review[]
  partiesLed    Party[]       @relation("PartyLeader") 
  joinedParties PartyMember[] 
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Restaurant {
  id          String            @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  name        String
  description String?           @db.Text
  lat         Float
  lng         Float
  category    String?
  
  // Relations
  images      RestaurantImage[] 
  reviews     Review[]
  menus       Menu[]
  parties     Party[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
}

model RestaurantImage {
  id           String     @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  url          String     
  isCover      Boolean    @default(false) 
  
  // Relations
  restaurantId String     // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
}

model Menu {
  id           String     @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  name         String
  description  String?    @db.Text
  price        Float      
  category     String     @default("others")
  imageUrl     String?
  
  // Relations
  restaurantId String     // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Party {
  id              String        @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  name            String?       
  details         String?       @db.Text 
  meetupTime      DateTime      
  maxParticipants Int           
  status          PartyStatus   @default(OPEN)
  contactInfo     String        
  
  // Relations
  restaurantId    String        // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  leaderId        String        // 🌟 เปลี่ยน Foreign Key เป็น String
  leader          User          @relation("PartyLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  
  members         PartyMember[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PartyMember {
  id        String   @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  joinedAt  DateTime @default(now())
  
  // Relations
  partyId   String   // 🌟 เปลี่ยน Foreign Key เป็น String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  
  userId    String   // 🌟 เปลี่ยน Foreign Key เป็น String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraint: ป้องกัน User คนเดิมกดเข้าร่วมตี้เดิมซ้ำ
  @@unique([partyId, userId])
}

model Review {
  id           String     @id @default(uuid()) // 🌟 เปลี่ยนเป็น UUID
  rating       Int        
  comment      String?    @db.Text
  
  // Relations
  userId       String     // 🌟 เปลี่ยน Foreign Key เป็น String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  restaurantId String     // 🌟 เปลี่ยน Foreign Key เป็น String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}